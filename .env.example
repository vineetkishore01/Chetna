# Chetna - God-Tier Memory System
# Copy this to .env and configure

# ===================
# Server Configuration
# ===================
CHETNA_PORT=1987
CHETNA_DB_PATH=./data/chetna.db
CHETNA_LOG_LEVEL=info

# ===================
# Embedding Configuration
# ===================
# Provider: ollama, openai, google, openrouter
EMBEDDING_PROVIDER=ollama

# Model names (depending on provider)
# Ollama: nomic-embed-text, mxbai-embed-large, gemma3-embed-e2b, bge-m3
# OpenAI: text-embedding-3-small, text-embedding-3-large
# Google: gemini-embedding-001, gemini-embedding-2
EMBEDDING_MODEL=nomic-embed-text

# Base URL for Ollama (or custom OpenAI-compatible)
EMBEDDING_BASE_URL=http://localhost:11434

# API Key for OpenAI/Google/OpenRouter (leave empty for local Ollama)
# EMBEDDING_API_KEY=sk-your-key-here

# ===================
# Vector Database
# ===================
# Use LanceDB for large-scale vector storage (optional)
# USE_LANCEDB=false
# LANCEDB_PATH=./data/lancedb

# ===================
# Cache Configuration
# ===================
SESSION_CACHE_SIZE=100
